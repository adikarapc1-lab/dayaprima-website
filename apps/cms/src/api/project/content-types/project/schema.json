{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Housing projects shown on the website"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "houseTypes": {
      "type": "component",
      "repeatable": true,
      "component": "project.house-type"
    },
    "facilities": {
      "type": "component",
      "repeatable": true,
      "component": "project.facility"
    },
    "location": {
      "type": "string"
    },
    "mapEmbedUrl": {
      "type": "text"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}
